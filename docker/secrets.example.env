# Example secrets for building/running the Docker image
# Copy this file to `docker/secrets.env` and fill in real values before running the scripts.
# DO NOT commit the actual `docker/secrets.env` with real secrets to version control.

# Discord bot token (required)
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Optional: run-time settings
# DOTNET_ENVIRONMENT=Production
# LOG_LEVEL=Information
